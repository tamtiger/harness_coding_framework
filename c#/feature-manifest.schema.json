{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/harness-coding-framework/csharp/feature-manifest.schema.json",
  "title": "AI-Native Feature Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "feature",
    "module",
    "type",
    "dependencies",
    "layers_touched",
    "permissions",
    "events",
    "ai_status"
  ],
  "properties": {
    "feature": {
      "type": "string",
      "minLength": 1
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["Command", "Query"]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "layers_touched": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Domain.Shared",
          "Domain",
          "Application.Contracts",
          "Application",
          "EntityFrameworkCore",
          "HttpApi",
          "HttpApi.Host",
          "Tests"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "events": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "ai_status": {
      "type": "string",
      "enum": ["Complete", "Draft", "NeedsReview"]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Optional semver string tracking feature manifest evolution (e.g., 1.0.0)."
    }
  }
}
